# ---------------------------------------------------------------------
# Função unificada de backup para dotfiles
# Comita apenas os caminhos especificados.
#
# Aceita argumentos:
#   zsh
#   scripts (NOVO)
#   dconf-keys
#   dconf-exts
#   dconf-all
#   all
# ---------------------------------------------------------------------
dotfiles_bkp() {
    # --- Caminhos ---
    local REPO_DIR=~/dotfiles
    local ZSH_DIR=~/dotfiles/zsh
    local DCONF_DIR=~/dotfiles/gnome-dconf
    local SCRIPT_DIR=~/dotfiles/scripts # <-- MUDANÇA AQUI
    local argument="$1"

    # Garante que o diretório dconf exista
    mkdir -p "$DCONF_DIR"

    # --- Funções Internas de Backup ---

    _bkp_dconf_keys() {
        echo "-> Fazendo backup dos Atalhos de Teclado..."
        dconf dump /org/gnome/settings-daemon/plugins/media-keys/ > "$DCONF_DIR/gnome-keybindings-media.dconf"
        dconf dump /org/gnome/desktop/wm/keybindings/ > "$DCONF_DIR/gnome-keybindings-wm.dconf"
        dconf dump /org/gnome/shell/keybindings/ > "$DCONF_DIR/gnome-keybindings-shell.dconf"
        
        git -C "$REPO_DIR" add "$DCONF_DIR/gnome-keybindings-media.dconf" "$DCONF_DIR/gnome-keybindings-wm.dconf" "$DCONF_DIR/gnome-keybindings-shell.dconf"
    }

    _bkp_dconf_exts() {
        echo "-> Fazendo backup das Extensões..."
        dconf dump /org/gnome/shell/extensions/ > "$DCONF_DIR/gnome-extensions-settings.dconf"
        
        git -C "$REPO_DIR" add "$DCONF_DIR/gnome-extensions-settings.dconf"
    }

    _bkp_zsh() {
        echo "-> Fazendo backup dos arquivos Zsh..."
        git -C "$REPO_DIR" add "$ZSH_DIR"
    }

    _bkp_script() {
        echo "-> Fazendo backup da pasta scripts..." # <-- MUDANÇA AQUI
        git -C "$REPO_DIR" add "$SCRIPT_DIR"
    }

    # --- Função Interna de Commit ---
    # $1 = 'auto' ou 'ask' (modo de commit)
    # $2 = A mensagem (se 'auto') ou o Padrão (se 'ask')
    # $3, $4, ... = Os caminhos para comitar
    _bkp_commit_push() {
        local mode="$1"
        local message="$2"
        shift 2 # Remove 'mode' e 'message' da lista
        local paths=("$@") # Pega o resto dos argumentos como os caminhos
        local commit_message=""

        # Verifica se há alterações no 'stage' *apenas* para os caminhos especificados
        if ! git -C "$REPO_DIR" diff --quiet --staged -- "${paths[@]}"; then
            echo "-> Novas alterações encontradas."

            if [ "$mode" = "ask" ]; then
                echo "Digite a mensagem do commit (Padrão: '$message'):"
                read -p "> " commit_message
                if [ -z "$commit_message" ]; then
                    commit_message="$message"
                fi
            else
                # Modo 'auto'
                commit_message="$message"
            fi
            
            echo "-> Fazendo commit: '$commit_message'"
            # Comita APENAS os caminhos especificados
            git -C "$REPO_DIR" commit -m "$commit_message" -- "${paths[@]}" 
            
            echo "-> Enviando para o repositório..."
            git -C "$REPO_DIR" push
        else
            echo "-> Nenhuma alteração. Nada para enviar."
        fi
    }
    # --- Fim das Funções Internas ---


    # --- Lógica Principal ---
    echo "Iniciando backup dos dotfiles..."

    if [ -z "$argument" ]; then
        echo "ERRO: Nenhum argumento fornecido."
        echo "Uso: dotfiles_bkp [zsh | scripts | dconf-keys | dconf-exts | dconf-all | all]"
        return 1
    fi

    case "$argument" in
        zsh)
            _bkp_zsh
            _bkp_commit_push "ask" "Atualizar arquivos de configuração Zsh" "$ZSH_DIR"
            ;;
        scripts)
            _bkp_script
            _bkp_commit_push "ask" "Atualizar scripts" "$SCRIPT_DIR"
            ;;
        dconf-keys)
            _bkp_dconf_keys
            _bkp_commit_push "auto" "Atualizar atalhos de teclado" "$DCONF_DIR/gnome-keybindings-media.dconf" "$DCONF_DIR/gnome-keybindings-wm.dconf" "$DCONF_DIR/gnome-keybindings-shell.dconf"
            ;;
        dconf-exts)
            _bkp_dconf_exts
            _bkp_commit_push "auto" "Atualizar configurações de extensões" "$DCONF_DIR/gnome-extensions-settings.dconf"
            ;;
        dconf-all)
            _bkp_dconf_keys
            _bkp_dconf_exts
            _bkp_commit_push "auto" "Atualizar configurações dconf" "$DCONF_DIR"
            ;;
        all)
            _bkp_zsh
            _bkp_script
            _bkp_dconf_keys
            _bkp_dconf_exts
            _bkp_commit_push "ask" "Atualizar dotfiles" "$ZSH_DIR" "$DCONF_DIR" "$SCRIPT_DIR"
            ;;
        *)
            echo "ERRO: Argumento '$argument' inválido."
            echo "Uso: dotfiles_bkp [zsh | scripts | dconf-keys | dconf-exts | dconf-all | all]"
            return 1
            ;;
    esac

    echo "Backup concluído!"
}
